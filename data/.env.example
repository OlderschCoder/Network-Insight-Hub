# ============================================================
# SCCC IT Tech Support Portal — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ------------------------------------------------------------
# DATABASE (required)
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:password@localhost:5432/sccc_it_portal

# ------------------------------------------------------------
# ZENDESK (required for ticket forwarding)
# 1. Go to: https://sccc.zendesk.com/admin/apps-integrations/apis/zendesk-api/settings
# 2. Enable "Token Access"
# 3. Click "Add API token" — copy the 40-character token
# ------------------------------------------------------------
ZENDESK_API_TOKEN_SCCC=your-40-character-api-token-here
ZENDESK_ADMIN_EMAIL=mark.bojeun@sccc.edu
ZENDESK_SUBDOMAIN=sccc

# ------------------------------------------------------------
# ADMIN PASSWORD (strongly recommended for production)
# Protects the /admin panel with a password.
# Leave blank or unset to disable auth (development only).
# ------------------------------------------------------------
ADMIN_PASSWORD=

# ------------------------------------------------------------
# NODE ENVIRONMENT
# Use "production" for IIS/deployed environments.
# Use "development" for local dev.
# ------------------------------------------------------------
NODE_ENV=development

# ------------------------------------------------------------
# PORT (optional)
# The port the Express server listens on.
# Default: 5000. IIS via iisnode manages this automatically.
# ------------------------------------------------------------
# PORT=5000
