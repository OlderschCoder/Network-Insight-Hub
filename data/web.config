<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- iisnode: tells IIS to hand requests to Node.js -->
    <handlers>
      <add name="iisnode" path="dist/index.cjs" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Don't rewrite iisnode internal requests -->
        <rule name="iisnode" stopProcessing="true">
          <match url="dist/index.cjs" />
        </rule>

        <!-- Serve static files from dist/public directly -->
        <rule name="StaticFiles" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions>
            <add input="{DOCUMENT_ROOT}\dist\public\{R:1}" matchType="IsFile" />
          </conditions>
          <action type="Rewrite" url="dist/public/{R:1}" />
        </rule>

        <!-- Route everything else through the Node.js server -->
        <rule name="NodeApp" stopProcessing="true">
          <match url="^(.*)$" />
          <action type="Rewrite" url="dist/index.cjs" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode configuration -->
    <iisnode
      node_env="production"
      nodeProcessCommandLine="node"
      interceptor="&quot;%programfiles%\iisnode\interceptor.js&quot;"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment=".env" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
