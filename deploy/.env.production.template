# =============================================================================
# SCCC IT Reporting Hub — production environment
# =============================================================================
# USAGE (on the Azure VM):
#   sudo cp deploy/.env.production.template /opt/sccc-it/.env.production
#   sudo nano /opt/sccc-it/.env.production        # fill in every <...> secret
#   sudo chown root:root /opt/sccc-it/.env.production
#   sudo chmod 600 /opt/sccc-it/.env.production
#   sudo systemctl restart sccc-api
#
# RULES:
#   - No spaces around "=", no quotes needed unless a value contains "#" or spaces.
#   - Every "<...>" below is a placeholder you MUST replace.
#   - Lines that are already filled in are non-secret identifiers, safe as-is.
#   - Config is read ONLY at process start -> restart the service after editing.
# =============================================================================

# ---- Core (required) --------------------------------------------------------
NODE_ENV=production
PORT=8080
# Postgres connection string. Must be the FIRST token on this line (no stray
# leading characters) or the app fails with "DATABASE_URL must be set".
DATABASE_URL=postgres://sccc:<DB_PASSWORD>@localhost:5432/sccc_it

# ---- Microsoft Entra ID SSO (required for login) ----------------------------
ENTRA_TENANT_ID=b88f2663-5600-40a5-a4d2-294302a50efc
ENTRA_CLIENT_ID=63398a03-87d2-4260-a8bc-02ca3df362b6
# Paste the app-registration secret VALUE (not the Secret ID / GUID).
ENTRA_CLIENT_SECRET=<ENTRA_CLIENT_SECRET_VALUE>
ENTRA_REDIRECT_URI=https://sccc-itreporting.centralus.cloudapp.azure.com/api/auth/entra/callback
# Access gate (fail-closed). IT / InfoTech group's Entra cloud Object Id.
ENTRA_ALLOWED_GROUP_IDS=7e3e10cd-36a5-4f07-9188-e1f24cb4d408
# Optional alternative/extra gate (comma-separated app-role values):
# ENTRA_ALLOWED_APP_ROLES=
# Optional overrides:
# ENTRA_ROLE_MAP_JSON={"network":"network_engineer"}
# ENTRA_POST_LOGIN_REDIRECT=https://sccc-itreporting.centralus.cloudapp.azure.com/

# ---- Break-glass admin (recommended: emergency login if SSO is down) --------
BREAKGLASS_EMAIL=cio@sccc.edu
BREAKGLASS_PASSWORD=<STRONG_BREAKGLASS_PASSWORD>

# ---- AI (OpenAI) ------------------------------------------------------------
# NOTE: the app reads ONLY these two vars (a plain OPENAI_API_KEY is ignored).
# Base URL must be EXACTLY this — no trailing characters.
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=<OPENAI_API_KEY>

# ---- Zendesk ----------------------------------------------------------------
ZENDESK_SUBDOMAIN=sccc
ZENDESK_EMAIL=mark.bojeun@sccc.edu
ZENDESK_API_TOKEN=<ZENDESK_API_TOKEN>
# Optional (defaults shown / handled in code):
# ZENDESK_GROUP=Onsite_it
# ZENDESK_WIDGET_KEY=

# ---- Azure VM inventory sync (service principal, needs Reader at sub scope) --
# Same tenant as SSO; verify the SP client/subscription values.
AZURE_TENANT_ID=b88f2663-5600-40a5-a4d2-294302a50efc
AZURE_CLIENT_ID=<AZURE_SP_CLIENT_ID>
AZURE_CLIENT_SECRET=<AZURE_SP_CLIENT_SECRET>
AZURE_SUBSCRIPTION_ID=<AZURE_SUBSCRIPTION_ID>

# ---- Email (Option A: dedicated sender mailbox, "Send As" itech) ------------
# Authenticate as the NEW licensed mailbox; send appears FROM itech@sccc.edu.
# Requires: SMTP AUTH enabled on the sender + Send As on itech (see
# deploy/configure-o365-sender.ps1). Port 587 = STARTTLS (auto).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=it-reporting@sccc.edu
SMTP_PASS=<SENDER_MAILBOX_PASSWORD>
SMTP_FROM=itech@sccc.edu

# ---- FortiGate web-filter whitelist (optional; on-network/VPN only) ---------
# FORTIGATE_HOST=192.168.1.1
# FORTIGATE_API_TOKEN=<FORTIGATE_API_TOKEN>
# FORTIGATE_VDOM=root
# FORTIGATE_WEBFILTER_PROFILE=default
# FORTIGATE_VERIFY_SSL=false

# ---- Logging (optional) -----------------------------------------------------
# LOG_LEVEL=info
